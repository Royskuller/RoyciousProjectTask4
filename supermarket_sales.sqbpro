s/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SELECT+WHERE*">SELECT *
FROM supermarket_sales_cleaned
WHERE City = 'Yangon';</sql><sql name="ORDER BY*">SELECT *
FROM supermarket_sales_cleaned
ORDER BY Total DESC;</sql><sql name="GROUP BY*">SELECT City,
	SUM(Total) AS TotalSales
FROM supermarket_sales_cleaned
GROUP BY City;</sql><sql name="AVG*">SELECT ProductLine,
		AVG(Rating) AS AvgRating
FROM supermarket_sales_cleaned
GROUP BY ProductLine;</sql><sql name="SUM*">SELECT Payment,
	SUM(Total) AS Revenue
FROM supermarket_sales_cleaned
GROUP BY Payment;</sql><sql name="Subquery*">SELECT *
FROM supermarket_sales_cleaned
WHERE Total &gt;
(
	SELECT AVG(Total)
	FROM supermarket_sales_cleaned
);</sql><sql name="View*">-- CREATE VIEW SalesSummary AS
-- SELECT city,
-- 	SUM(total) AS TotalSales
-- FROM supermarket_sales_cleaned
-- GROUP BY city;
SELECT *
FROM SalesSummary
</sql><sql name="Index*">-- CREATE INDEX idx_city
-- ON supermarket_sales_cleaned(City);
PRAGMA index_list('supermarket_sales_cleaned');</sql><sql name="Join*">-- CREATE TABLE CustomerTypeInfo (
-- 	CustomerType TEXT,
-- 	DiscountRate REAL
-- );
-- INSERT INTO CustomerTypeInfo VALUES ('Member',0.10);
-- INSERT INTO CustomerTypeInfo VALUES ('Normal',0.00);
SELECT s.InvoiceID,
		s.CustomerType,
		c.DiscountRate
FROM supermarket_sales_cleaned s
INNER JOIN CustomerTypeInfo c
ON s.CustomerType = c.CustomerType;</sql><current_tab id="8"/></tab_sql></sqlb_project>
